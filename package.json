{
  "name": "obsidian-eltts",
  "version": "0.1.0",
  "description": "An Obsidian plugin that reads notes aloud using the ElevenLabs API.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "elevenlabs",
    "text-to-speech",
    "tts"
  ],
  "author": "Keith Smith",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.1",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.4.3"
  }
}
